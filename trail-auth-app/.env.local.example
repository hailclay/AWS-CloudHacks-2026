# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Auth0 (already set up in your app — copy from your existing config)
VITE_AUTH0_DOMAIN=your-domain.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id

# Auth0 API audience — create an API in Auth0 dashboard, use its identifier here
# This is what tells Auth0 to issue a JWT your Lambda can verify
VITE_AUTH0_AUDIENCE=https://trailmatch-api

# Lambda API URL — printed by `sam deploy` in the Outputs section
VITE_API_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/prod

# Google Maps API key — needed for Phase 2 map features
VITE_GOOGLE_MAPS_KEY=your-google-maps-api-key
